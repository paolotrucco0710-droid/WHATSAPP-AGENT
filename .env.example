DATABASE_URL=./data/flexi.db
PORT=3000
NODE_ENV=development

# OpenAI (consigliato in produzione)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Timeout stato conversazione in minuti (default 30)
CONVERSATION_TIMEOUT_MINUTES=30

# Provider messaggistica: twilio | meta (auto se le variabili sono impostate)
MESSAGING_PROVIDER=

# --- Twilio WhatsApp (consigliato) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Numero Flexi su Twilio, es. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# --- Meta WhatsApp Cloud API (alternativa) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Pilot: solo questi barbieri possono usare Flexi (numeri separati da virgola)
# Se vuoto, chiunque scriva al numero Flexi viene accettato
BARBER_ALLOWLIST=

# Briefing giornaliero (piano oggi)
BRIEFING_AVERAGE_PRICE=25
BRIEFING_RECOVERY_WEEKS=5
BRIEFING_WORK_START=09:00
BRIEFING_WORK_END=19:00
BRIEFING_MAX_RECOVERY=3
BRIEFING_MAX_NOSHOW=3
BRIEFING_MAX_SLOT_CLIENTS=2

# Produzione: API per pre-configurare barbieri (POST /admin/barber)
ADMIN_SECRET=

# Report mattutino automatico (Europe/Rome, default 08:00)
MORNING_REPORT_ENABLED=true
MORNING_REPORT_HOUR=8
MORNING_REPORT_MINUTE=0
# Opzionale: trigger manuale POST /cron/morning-report
CRON_SECRET=
