DATABASE_URL=./data/flexi.db
PORT=3000
NODE_ENV=development

# OpenAI (consigliato in produzione)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Timeout stato conversazione in minuti (default 30)
CONVERSATION_TIMEOUT_MINUTES=30

# WhatsApp Cloud API — lascia vuoto finché Meta non è configurato
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Pilot: solo questi barbieri possono usare Flexi (numeri separati da virgola)
# Se vuoto, chiunque scriva al numero Flexi viene accettato
BARBER_ALLOWLIST=

# Produzione: API per pre-configurare barbieri (POST /admin/barber)
ADMIN_SECRET=
